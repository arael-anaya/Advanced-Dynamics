#!/usr/bin/env bash
# Recompiles any staged .tex file and stages the resulting PDF, so a
# committed PDF always matches the LaTeX source it was built from.
# Aborts the commit if a file fails to compile.
set -euo pipefail

staged_tex=$(git diff --cached --name-only --diff-filter=ACM -- '*.tex')
[ -z "$staged_tex" ] && exit 0

while IFS= read -r texfile; do
    dir=$(dirname "$texfile")
    file=$(basename "$texfile")
    echo "==> Compiling $texfile"
    (cd "$dir" && latexmk -pdf -interaction=nonstopmode -halt-on-error -file-line-error "$file")
    pdf="${texfile%.tex}.pdf"
    [ -f "$pdf" ] && git add "$pdf"
done <<< "$staged_tex"
